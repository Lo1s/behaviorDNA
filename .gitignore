# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/

# Coverage / test artifacts
.coverage
.coverage.*
htmlcov/
coverage.xml

# DVC internals
.dvc/cache/
.dvc/tmp/

# Data — managed by DVC, not Git
data/raw/*
data/processed/*
data/splits/*
data/external/*
data/synthetic/*
!data/**/.gitkeep
# ...but the corpus-layout README + empty Phase-6 corpus dirs are tracked
# (a file can't be re-included if its parent dir is excluded, hence the
#  re-include-dir / ignore-contents / re-include-keep dance).
# NOTE: data/raw is a whole-dir DVC output, so nothing inside it is git-tracked
# (DVC forbids SCM-tracked files in an output dir). Its layout doc lives in
# docs/DATA_LAYOUT.md instead.
!data/external/README.md
!data/external/balabit/
data/external/balabit/*
!data/external/balabit/.gitkeep
!data/external/sapimouse/
data/external/sapimouse/*
!data/external/sapimouse/.gitkeep

# Adversarial benchmark outputs — regenerated by scripts
reports/adversarial/*
!reports/adversarial/.gitkeep

# Models — managed by DVC
models/*.pkl
models/*.onnx
models/*.pt
!models/.gitkeep

# MLflow
mlruns/
mlartifacts/

# Hydra outputs
outputs/
.hydra/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.env
dagshub_token.txt

# Collector
collector/BehaviorDNA_Recorder.exe
collector/dist/
collector/build/
collector/*.spec
